# Ollama configuration for AI Chat
# Copy to .env and adjust if needed

# Base URL for Ollama API (leave empty to use dev server proxy to localhost:11434)
# Set to http://localhost:11434 for production if running Ollama locally
REACT_APP_OLLAMA_URL= http://localhost:11434
#disable host
DANGEROUSLY_DISABLE_HOST_CHECK=true
# Model name (default: llama3.2)
REACT_APP_OLLAMA_MODEL=llama3.2
